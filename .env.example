# 阿里云通义千问配置
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek 配置（如需要）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# GLM 配置（如需要）
ANTHROPIC_AUTH_API=your_glm_api_key_here
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# CORS 配置（可选）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 搜索代理（可选，墙内访问DuckDuckGo/Bing时使用）
# SEARCH_PROXY=http://127.0.0.1:7890
# SEARCH_TIMEOUT=15

# HuggingFace 镜像配置（墙内使用）
# 使用国内镜像源加速模型下载
HUGGINGFACE_HUB_CACHE=./cache/huggingface
HUGGINGFACE_ASSETS_CACHE=./cache/huggingface
# 以下配置二选一，推荐使用阿里云镜像
# 阿里云镜像（推荐）
HF_ENDPOINT=https://www.modelscope.cn/api/v1
# 或使用 huggingface.co 的镜像
# HF_ENDPOINT=https://hf-mirror.com
